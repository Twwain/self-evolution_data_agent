# 环境变量模板
# 复制为 .env 并填写实际值

# LLM 提供商 — 按线协议分轴 (openai | anthropic)
#   openai    → OpenAI Chat Completions 协议 (DashScope/Qwen, DeepSeek, vLLM, 官方 OpenAI…)
#   anthropic → Anthropic Messages 协议 (Claude)
IS_LLM_PROVIDER=openai

# OpenAI 协议端点配置 (默认 DashScope/Qwen, 改 BASE_URL 即可接任意兼容端点)
IS_LLM_API_KEY=your-dashscope-api-key
IS_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IS_LLM_MODEL=qwen-plus

# Claude (Anthropic) 配置
IS_CLAUDE_API_KEY=your-anthropic-api-key
IS_CLAUDE_MODEL=claude-sonnet-4-20250514
IS_CLAUDE_BASE_URL=https://api.anthropic.com

# Git 仓库访问令牌 (可选，私有仓库需要)
# GitHub: ghp_xxxxxxxxxxxx
# GitLab: glpat-xxxxxxxxxxxx
# Gitee: xxxxxxxxxxxx
IS_GIT_TOKEN=
