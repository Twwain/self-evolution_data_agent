# ════════════════════════════════════════════════════════════
# DEV 环境配置模板 — 复制为 backend/.env 并填真实值 (本地裸跑读此文件)
#   cd backend && cp .env.example .env
# 启动: make dev-backend (uvicorn :8001, CWD=backend 时 pydantic 自动读 .env)
# ⚠ 仅占位符, 禁填真实密钥 (本仓可开源)
# ════════════════════════════════════════════════════════════

# ── 元数据库 PostgreSQL (dev 连本地或测试 RDS) ──
IS_METADATA_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/self_evolution_data_agent

# ── Git 仓库访问令牌 (私有仓库需要) ──
IS_GIT_TOKEN=

# ── 数据源凭证加密 Fernet key (urlsafe-base64, 32 字节) ──
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IS_DATASOURCE_ENCRYPTION_KEY=

# ── JWT 认证 (生产务必改) ──
IS_JWT_SECRET=change-me-in-production

# ── Oracle Driver Pool ──────────────────────────────────────────────────────
# 本项目使用 Thick mode + Oracle Instant Client 19，支持 Oracle 11g+。
#
# 安装 Instant Client 19 后，将下方路径改为实际解压目录并取消注释。
#
# macOS (Intel/x86, Rosetta):
#   IS_ORACLE_THICK_MODE_LIB_DIR=/usr/local/oracle/instantclient_19_8
#
# Linux x86_64:
#   IS_ORACLE_THICK_MODE_LIB_DIR=/opt/oracle/instantclient_19_8
#
IS_ORACLE_THICK_MODE_LIB_DIR=
# IS_ORACLE_POOL_MIN_SIZE=0
# IS_ORACLE_POOL_MAX_SIZE=5
# IS_ORACLE_POOL_INCREMENT=1
# IS_ORACLE_POOL_TIMEOUT_SECS=10
# IS_ORACLE_QUERY_TIMEOUT_SECS=30
# IS_ORACLE_CONNECT_TIMEOUT_SECS=10

# ── Langfuse 追踪 (留空禁用, 不影响主流程) ──
IS_LANGFUSE_HOST=
IS_LANGFUSE_PUBLIC_KEY=
IS_LANGFUSE_SECRET_KEY=
IS_LANGFUSE_DEBUG_PAYLOAD_SIZE=false
