# ════════════════════════════════════════════════════════════
# DEV 环境配置模板 — 复制为 backend/.env 并填真实值 (本地裸跑读此文件)
#   cd backend && cp .env.example .env
# 启动: make dev-backend (uvicorn :8001, CWD=backend 时 pydantic 自动读 .env)
# ⚠ 仅占位符, 禁填真实密钥 (本仓可开源)
# ════════════════════════════════════════════════════════════

# ── LLM 提供商 (按线协议分轴: openai | anthropic) ──
IS_LLM_PROVIDER=openai

# ── OpenAI 协议端点 (DashScope/Qwen / DeepSeek / vLLM / 官方 OpenAI) ──
IS_LLM_API_KEY=your-llm-api-key
IS_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IS_LLM_MODEL=qwen-plus

# ── Claude (Anthropic 协议) ──
IS_CLAUDE_API_KEY=your-anthropic-api-key
IS_CLAUDE_MODEL=claude-sonnet-4-20250514
IS_CLAUDE_BASE_URL=https://api.anthropic.com

# ── Embedding (独立凭证, 见 config.py 注释) ──
IS_EMBEDDING_API_KEY=your-embedding-api-key
IS_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IS_EMBEDDING_MODEL=text-embedding-v4

# ── 元数据库 PostgreSQL (dev 连本地或测试 RDS) ──
IS_METADATA_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intelligent_statistics

# ── Git 仓库访问令牌 (私有仓库需要) ──
IS_GIT_TOKEN=

# ── 数据源凭证加密 Fernet key (urlsafe-base64, 32 字节) ──
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IS_DATASOURCE_ENCRYPTION_KEY=

# ── JWT 认证 (生产务必改) ──
IS_JWT_SECRET=change-me-in-production

# ── Langfuse 追踪 (留空禁用, 不影响主流程) ──
IS_LANGFUSE_HOST=
IS_LANGFUSE_PUBLIC_KEY=
IS_LANGFUSE_SECRET_KEY=
IS_LANGFUSE_DEBUG_PAYLOAD_SIZE=false
