# ════════════════════════════════════════════════════════════
# PROD 环境配置模板 — 复制为 backend/.env.prod 并填真实值
#   cd backend && cp .env.prod.example .env.prod
# 用法: compose 经 env_file 注入容器环境变量 (见 docker-compose.prod.yml)
#   make prod-up
# ⚠ 仅占位符, 禁填真实密钥; .env.prod 已 gitignored 永不入库
# ⚠ 本模板只含「必填凭证 + 生产高频阈值」, 非全部 151 个 IS_ 字段;
#   其余字段保留 config.py 默认值, 需覆盖时按 IS_<UPPER_SNAKE> 追加于此。
# ════════════════════════════════════════════════════════════

# ── 元数据库 PostgreSQL (目标机宿主机现有库, 见 AD-3) ──
# 容器内 localhost 指容器自己; 宿主机 PG 用 host.docker.internal
# 密码用目标机现有 backend/.env 的真实值 (现裸机能跑通即正确); 库 self_evolution_data_agent 保留直连
# 宿主机须 (Stage0): listen_addresses='*' + pg_hba.conf 放行 docker 网段 + reload
IS_METADATA_DB_URL=postgresql+asyncpg://postgres:__FILL_PROD_DB_PASSWORD__@host.docker.internal:5432/self_evolution_data_agent

# ── ChromaDB 向量库持久化 (见 AD-7) ──
# IS_CHROMA_HOST_PATH: 宿主机目录 (compose 解析期插值 → bind mount 源)。目标机 = /data/chromadb
#   (系统盘 ext4 普通目录; Stage0 已把现有 new_energy 向量迁入此目录)
#   ⚠ 须本地文件系统 (ext4/xfs); 若未来换网络盘 NFS/NAS 会致 SQLite 损坏 — 避开
# IS_CHROMA_PERSIST_DIR: 容器内路径 (固定, = bind mount 目标; registry.py 据此创建)
IS_CHROMA_HOST_PATH=/data/chromadb
IS_CHROMA_PERSIST_DIR=/app/data/chroma

# ── Git 仓库访问令牌 ──
IS_GIT_TOKEN=

# ── 数据源凭证加密 Fernet key (生产必填! 不填则用 dev 默认 key = 形同未加密) ──
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IS_DATASOURCE_ENCRYPTION_KEY=__FILL_PROD_FERNET_KEY__

# ── JWT 认证 (生产必填强随机) ──
# 生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
IS_JWT_SECRET=__FILL_PROD_JWT_SECRET__

# ── Langfuse 追踪 ──
IS_LANGFUSE_HOST=https://us.cloud.langfuse.com
IS_LANGFUSE_PUBLIC_KEY=__FILL_PROD_LANGFUSE_PK__
IS_LANGFUSE_SECRET_KEY=__FILL_PROD_LANGFUSE_SK__
IS_LANGFUSE_DEBUG_PAYLOAD_SIZE=false

# ════════════════════════════════════════════════════════════
# 生产高频调优项 (默认值见 config.py; 下列为 config.py 现默认, 按需改)
# ════════════════════════════════════════════════════════════

# ── 查询行数上限 (结果集过大时调) ──
IS_QUERY_ROW_LIMIT=1000

# ── 元数据库连接池 (并发高时上调 size/overflow) ──
IS_METADATA_POOL_SIZE=20
IS_METADATA_POOL_MAX_OVERFLOW=30
IS_METADATA_POOL_TIMEOUT_SECS=60

# ── 知识检索召回 k 值 (召回质量 vs 延迟权衡) ──
IS_KNOWLEDGE_RETRIEVE_CRITICAL_N=5
IS_KNOWLEDGE_RETRIEVE_NORMAL_N=5
IS_KNOWLEDGE_RETRIEVE_DEFAULT_K=5

# ── agent loop 配额 (烧钱/时延控制) ──
IS_AGENT_LOOP_MAX_TOTAL_ITERATIONS=40
IS_AGENT_LOOP_CONTEXT_LIMIT_TOKENS=80000

# ── Oracle Thick mode (连 Oracle 11g+; 不配则 Thin mode 仅 12.1+, 旧库报 DPY-3010) ──
#  Dockerfile 已装 Instant Client 21.15 Basic Lite 并设此默认路径;
#  此处显式声明作配置权威, 与 Dockerfile ENV 同值 (compose env_file 覆盖优先级更高).
#  排障: 若 11g 仍报 DPY-3010, 先 docker exec <c> ls /opt/oracle 确认镜像含本层.
IS_ORACLE_THICK_MODE_LIB_DIR=/opt/oracle/instantclient_21_15
