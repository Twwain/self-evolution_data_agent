# ════════════════════════════════════════════════════════════
# TEST 环境配置模板 — 复制为 backend/.env.test 并填真实值
#   cd backend && cp .env.test.example .env.test
# 用法: pytest 经 conftest load_dotenv(".env.test") 加载 (override=False, CI env 优先)
# 库名须以 _test 结尾; fixture 用事务回滚隔离, 不污染数据
# ⚠ 仅占位符, 禁填真实密钥
# ════════════════════════════════════════════════════════════

# 测试数据库 URL (独立测试库, 库名以 _test 结尾)
IS_TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/self_evolution_data_agent_test
