# ════════════════════════════════════════════════════════════
# TEST 环境配置模板 — 复制为 backend/.env.test 并填真实值
#   cd backend && cp .env.test.example .env.test
# 用法: pytest 经 conftest load_dotenv(".env.test") 加载 (override=False, CI env 优先)
# 库名须以 _test 结尾; fixture 用事务回滚隔离, 不污染数据
# ⚠ 仅占位符, 禁填真实密钥
# ════════════════════════════════════════════════════════════

# 测试数据库 URL (独立测试库, 库名以 _test 结尾)
IS_TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/self_evolution_data_agent_test

# e2e/集成测试用真实业务库凭据 (连库验证 + 画像). 不填则相关测试 skip.
# MySQL 路径 (建议用通用领域库, 勿用客户领域库)
E2E_MYSQL_HOST=__FILL__
E2E_MYSQL_PORT=3306
E2E_MYSQL_DB=__FILL__
E2E_MYSQL_USER=__FILL__
E2E_MYSQL_PASS=__FILL__
# MongoDB 路径
E2E_MONGO_HOST=__FILL__
E2E_MONGO_PORT=27017
E2E_MONGO_DB=__FILL__
E2E_MONGO_USER=__FILL__
E2E_MONGO_PASS=__FILL__

# 冷启动 LLM 行为验收 (Task 13) — 两个空库, 验 list_tables 空时 LLM 决策.
# 同一 host 两个空 database. 不填则 test_coldstart_llm_behavior_live skip.
E2E_MYSQL_A_HOST=__FILL__
E2E_MYSQL_A_PORT=3306
E2E_MYSQL_A_DB=__FILL__
E2E_MYSQL_A_USER=__FILL__
E2E_MYSQL_A_PASS=__FILL__
E2E_MYSQL_B_HOST=__FILL__
E2E_MYSQL_B_PORT=3306
E2E_MYSQL_B_DB=__FILL__
E2E_MYSQL_B_USER=__FILL__
E2E_MYSQL_B_PASS=__FILL__

# Oracle 集成测试路径 (不填则 test_oracle_* live tests skip)
IS_ORACLE_TEST_HOST=__FILL__
IS_ORACLE_TEST_PORT=1521
IS_ORACLE_TEST_SERVICE=__FILL__
IS_ORACLE_TEST_USER=__FILL__
IS_ORACLE_TEST_PASSWORD=__FILL__
